Package: amltargets
Title: Azure ML Target Factory for the targets Package
Version: 0.1.0
Authors@R: 
    person(
      given = "Jeffery", 
      family = "Leirness", 
      email = "jeffery.leirness@noaa.gov", 
      role = c("aut", "cre"), 
      comment = c(ORCID = "0000-0003-3604-2790")
